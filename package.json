{
  "name": "velocrafts-technologies",
  "version": "1.0.0",
  "private": true,
  "description": "Velocrafts Technologies - Frontend & Backend",
  "scripts": {
    "frontend": "cd velocraft-frontend && npm run dev",
    "backend": "cd velocraft-backend && npm start",
    "build:frontend": "cd velocraft-frontend && npm run build",
