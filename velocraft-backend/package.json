{
  "name": "lb4",
  "version": "0.0.1",
  "description": "API backend for Velocrafts Technologies",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "14 || 16 || 18 || 19"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "npm run eslint && npm run prettier:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run rebuild",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "preopenapi-spec": "npm run build",
    "openapi-spec": "node ./dist/openapi-spec",
    "create-db": "node scripts/create-db.js",
    "premigrate": "npm run create-db && npm run build",
    "migrate": "node ./dist/migrate",
    "prestart": "npm run rebuild",
    "start": "node -r source-map-support/register .",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "rebuild": "npm run clean && npm run build",
    "seed:blog": "node scripts/seed-blog-posts.js",
    "test:db": "node scripts/test-db-connection.js",
    "create:blog-table": "node scripts/create-blog-posts-table.js",
    "create:portfolio-table": "node scripts/create-portfolio-table.js",
    "generate:portfolio-seed": "node scripts/generate-portfolio-seed.js",
    "seed:portfolio": "node scripts/seed-portfolio.js"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Roshan Kolhe <kolheroshan508@gmail.com>",
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/boot": "^5.0.10",
    "@loopback/core": "^4.0.10",
    "@loopback/repository": "^5.1.5",
    "@loopback/rest": "^12.0.10",
    "@loopback/rest-explorer": "^5.0.10",
    "busboy": "^1.6.0",
    "dotenv": "^16.3.1",
    "loopback-connector-mysql": "^6.1.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.0",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@loopback/build": "^9.0.10",
    "@loopback/eslint-config": "^13.0.10",
    "@loopback/testlab": "^5.0.10",
    "@types/busboy": "^1.5.4",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^14.18.42",
    "eslint": "^8.38.0",
    "source-map-support": "^0.5.21",
    "typescript": "~4.9.5"
  }
}
